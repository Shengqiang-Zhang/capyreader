{
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": ["/assets/*", "/fonts/*", "/favicon.svg"]
  },
  "mimeTypes": {
    ".ttf": "font/ttf"
  },
  "globalHeaders": {
    "cache-control": "no-cache"
  },
  "routes": [
    {
      "route": "/assets/*",
      "headers": {
        "cache-control": "public, max-age=31536000, immutable"
      }
    },
    {
      "route": "/fonts/*",
      "headers": {
        "cache-control": "public, max-age=31536000, immutable"
      }
    }
  ]
}
